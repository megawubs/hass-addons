#!/bin/bash
set -e

MYSQL_DATADIR="/addon_config/mariadb"
mkdir -p "$MYSQL_DATADIR"
chown -R mysql:mysql "$MYSQL_DATADIR"

# Initialize data directory on first run
if [ ! -d "$MYSQL_DATADIR/mysql" ]; then
    echo "[mariadb] Initializing data directory at $MYSQL_DATADIR..."
    mysql_install_db --user=mysql --datadir="$MYSQL_DATADIR" --skip-test-db
    echo "[mariadb] Data directory initialized"
fi

echo "[mariadb] Starting mysqld..."
exec mysqld \
    --datadir="$MYSQL_DATADIR" \
    --bind-address=127.0.0.1 \
    --user=mysql \
    --skip-networking=OFF \
    --port=3306
